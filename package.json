{
  "name": "wa-tg-bot",
  "version": "1.0.0",
  "description": "WhatsApp ↔ Telegram AI Mirror Bot — Production-grade bridge with AI auto-reply, style learning, mood detection, and deep conversation memory.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "lint": "eslint src/ --ext .js",
    "db:reset": "node -e \"require('./src/db/index.js').resetDb()\"",
    "style:rebuild": "node -e \"require('./src/ai/styleProfile.js').rebuildStyleProfile()\"",
    "digest:test": "node -e \"require('./src/jobs/digest.js').sendDailyDigest()\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.8.0",
    "chrono-node": "^2.7.0",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "form-data": "^4.0.0",
    "franc": "^6.2.0",
    "grammy": "^1.21.1",
    "node-cron": "^3.0.3",
    "openai": "^4.28.0",
    "puppeteer": "^24.40.0",
    "puppeteer-core": "^22.0.0",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.2",
    "uuid": "^9.0.0",
    "vectra": "^0.12.3",
    "whatsapp-web.js": "^1.23.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "nodemon": "^3.0.3"
  },
  "keywords": [
    "whatsapp",
    "telegram",
    "bot",
    "ai",
    "automation",
    "bridge"
  ],
  "license": "MIT"
}
